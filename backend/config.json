{
  "ollama": {
    "model": "qwen3:0.6-q4_K_M",
    "base_url": "http://localhost:11434",
    "temperature": 0.7,
    "top_p": 0.9,
    "num_predict": 500
  },
  "agent": {
    "max_iterations": 5,
    "timeout": 300,
    "verbose": true
  },
  "layers": {
    "planner": {
      "enabled": false,
      "temperature": 0.5
    },
    "executor": {
      "enabled": false,
      "temperature": 0.7
    },
    "evaluator": {
      "enabled": false,
      "temperature": 0.5
    }
  },
  "cost_tracking": {
    "enabled": true,
    "log_level": "console",
    "log_file": "logs/costs.json",
    "track_latency": true,
    "track_tokens": true
  },
  "tools": {
    "enabled": [],
    "web_search": {
      "timeout": 10
    },
    "file_operations": {
      "allowed_paths": []
    }
  }
